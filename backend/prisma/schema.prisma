generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  nickname     String?
  avatar       String?
  phone        String?  @unique
  wechatOpenId String?  @unique @map("wechat_openid")
  role         String   @default("PARENT")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  teacherAuth     TeacherAuth?
  activities      Activity[]
  mediaAssets     MediaAsset[]
  pageViews       PageView[]
  parentContacts  ContactLog[] @relation("parent_contacts")
  teacherContacts ContactLog[] @relation("teacher_contacts")
  buyerOrders     Order[]

  @@map("users")
}

model TeacherAuth {
  id          String    @id @default(cuid())
  userId      String    @unique @map("user_id")
  realName    String    @map("real_name")
  idCardFront String?   @map("id_card_front")
  idCardBack  String?   @map("id_card_back")
  idCardNo    String?   @map("id_card_no")
  status      String    @default("PENDING")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  streetClaims StreetClaim[]
  products     Product[]

  @@map("teacher_auths")
}

model Instrument {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  claims   StreetClaim[]
  products Product[]

  @@map("instruments")
}

model StreetClaim {
  id           String    @id @default(cuid())
  teacherId    String    @map("teacher_id")
  instrumentId String    @map("instrument_id")
  streetName   String    @map("street_name")
  streetRaw    String?   @map("street_raw")
  district     String?
  city         String?
  province     String?
  lat          Float?
  lng          Float?
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now()) @map("created_at")
  releasedAt   DateTime? @map("released_at")

  teacher    TeacherAuth @relation(fields: [teacherId], references: [id])
  instrument Instrument  @relation(fields: [instrumentId], references: [id])

  @@unique([streetName, instrumentId])
  @@map("street_claims")
}

model Activity {
  id          String    @id @default(cuid())
  teacherId   String    @map("teacher_id")
  title       String
  description String?
  coverImage  String?   @map("cover_image")
  eventTime   DateTime? @map("event_time")
  location    String?
  price       Int?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  teacher User @relation(fields: [teacherId], references: [id])

  @@map("activities")
}

model Product {
  id           String   @id @default(cuid())
  teacherId    String   @map("teacher_id")
  instrumentId String   @map("instrument_id")
  name         String
  description  String?
  price        Int
  images       String   @default("[]")
  stock        Int      @default(-1)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  teacher    TeacherAuth @relation(fields: [teacherId], references: [id])
  instrument Instrument  @relation(fields: [instrumentId], references: [id])
  orders     Order[]

  @@map("products")
}

model Order {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  buyerId   String   @map("buyer_id")
  quantity  Int      @default(1)
  totalFee  Int      @map("total_fee")
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@map("orders")
}

model MediaAsset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("media_assets")
}

model PageView {
  id        String   @id @default(cuid())
  teacherId String   @map("teacher_id")
  visitorId String?  @map("visitor_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  teacher User @relation(fields: [teacherId], references: [id])

  @@map("page_views")
}

model ContactLog {
  id        String   @id @default(cuid())
  parentId  String   @map("parent_id")
  teacherId String   @map("teacher_id")
  fee       Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")

  parent  User @relation("parent_contacts", fields: [parentId], references: [id])
  teacher User @relation("teacher_contacts", fields: [teacherId], references: [id])

  @@map("contact_logs")
}
